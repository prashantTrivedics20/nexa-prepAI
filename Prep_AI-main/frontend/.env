# Frontend Configuration for Local Development

# Backend API Base URL
# For local development with Vite proxy, you can leave this commented out
# The proxy in vite.config.ts will handle /api requests to localhost:5000
# VITE_API_BASE_URL=http://localhost:5000/api

# Alternative: If you want to bypass the Vite proxy and connect directly
# Uncomment the line below:
# VITE_API_BASE_URL=http://localhost:5000/api

# Backend URL for Vite Proxy
# This is used by vite.config.ts for the proxy target
VITE_BACKEND_URL=http://localhost:5000

# Optional: Custom media/asset URLs
# VITE_MEDIA_BASE_URL=http://localhost:5000/media
