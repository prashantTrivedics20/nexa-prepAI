# PrepAI Environment Configuration Example
# Copy this file to create your .env files for backend and frontend

# ============================================
# BACKEND CONFIGURATION (backend/.env)
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/prepai

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI Provider Configuration
AI_PROVIDER=groq

# Groq Configuration (Recommended)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3-turbo

# xAI Configuration (Alternative)
# GROK_API_KEY=xai-your-api-key-here
# GROK_MODEL=grok-3-mini

# ============================================
# FRONTEND CONFIGURATION (frontend/.env)
# ============================================

# Backend URL for Vite Proxy
VITE_BACKEND_URL=http://localhost:5000

# Optional: Direct API connection (bypasses proxy)
# VITE_API_BASE_URL=http://localhost:5000/api
